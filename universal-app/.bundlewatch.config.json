{
  "$schema": "https://bundlewatch.io/schema.json",
  "files": [
    {
      "path": ".next/static/chunks/framework-*.js",
      "maxSize": "150kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/main-*.js",
      "maxSize": "250kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/radix-*.js",
      "maxSize": "100kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/libs-*.js",
      "maxSize": "200kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/commons-*.js",
      "maxSize": "100kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/pages/_app-*.js",
      "maxSize": "50kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/layout-*.js",
      "maxSize": "30kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/page-*.js",
      "maxSize": "50kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/dashboard/**/*.js",
      "maxSize": "80kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/transcriptions/**/*.js",
      "maxSize": "100kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/minutes/**/*.js",
      "maxSize": "80kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/chunks/app/admin/**/*.js",
      "maxSize": "100kb",
      "compression": "gzip"
    },
    {
      "path": ".next/static/css/**/*.css",
      "maxSize": "50kb",
      "compression": "gzip"
    }
  ],
  "defaultCompression": "gzip",
  "ci": {
    "trackBranches": ["main", "develop"],
    "repoBranchBase": "main",
    "commitStatusFailIfExceedsMax": true,
    "commitStatusFailIfNoBaseBranch": false
  },
  "normalizeFilenames": "^.+?(\\.\\w+)\\.(?:js|css)$"
}
