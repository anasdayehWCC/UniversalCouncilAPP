{
  "name": "universal-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:webpack",
    "dev:webpack": "next dev --webpack",
    "dev:turbo": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "analyze": "ANALYZE=true npm run build",
    "analyze:server": "BUNDLE_ANALYZE=server npm run build",
    "analyze:client": "BUNDLE_ANALYZE=client npm run build",
    "analyze:both": "BUNDLE_ANALYZE=both npm run build",
    "bundle-check": "node scripts/analyze-bundle.js",
    "bundle-check:ci": "node scripts/analyze-bundle.js --ci",
    "audit:premium-ui": "node scripts/audit-premium-ui.mjs",
    "size-limit": "size-limit",
    "size-limit:why": "size-limit --why",
    "openapi-ts": "openapi-ts",
    "openapi-ts:live": "OPENAPI_TS_INPUT=http://localhost:8080/api/openapi.json openapi-ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:codegen": "playwright codegen http://localhost:3000",
    "audit:a11y": "node scripts/audit-a11y-ci.mjs"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@azure/msal-browser": "^3.27.0",
