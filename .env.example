#For a full list of backend/worker settings and their description, see common/settings.py

DOCKER_BUILDER_CONTAINER=minute
APP_NAME=minute
ENVIRONMENT=local
APP_URL=http://localhost:3000
BACKEND_HOST=http://localhost:8080
NEXT_PUBLIC_BACKEND_HOST=http://localhost:8080
NEXT_PUBLIC_AUTH_STRATEGY=msal
NEXT_PUBLIC_AZURE_TENANT_ID=<entra_tenant_id>
NEXT_PUBLIC_AZURE_CLIENT_ID=<spa_client_id>
NEXT_PUBLIC_AZURE_API_SCOPE=api://<api-app-id>/.default
NEXT_PUBLIC_AZURE_REDIRECT_URI=http://localhost:3000
NEXT_PUBLIC_DEV_PREVIEW_MODE=false
NEXT_PUBLIC_DEFAULT_ORG_THEME=wcc

# === AWS ===
AWS_ACCOUNT_ID=<account_id>
AWS_REGION=eu-west-2
DATA_S3_BUCKET=i-dot-ai-dev-minute-data 

# We get these using aws-vault, docker compose picks them up from the environment variables
AWS_ACCESS_KEY_ID=<>
AWS_SECRET_ACCESS_KEY=<>
AWS_SESSION_TOKEN=<>

# === Azure LLM config ===
AZURE_OPENAI_API_KEY=<>
AZURE_OPENAI_ENDPOINT=<>
AZURE_DEPLOYMENT=<>
AZURE_API_VERSION=<>

# === select transcription services ===
TRANSCRIPTION_SERVICES=["azure_stt_synchronous", "azure_stt_batch"]

# === Azure transcription config ===
AZURE_SPEECH_KEY=<api key to access azure speech>
AZURE_SPEECH_REGION=<region of azure speech>
AZURE_SPEECH_API_VERSION=2025-10-15
AZURE_SPEECH_PHRASE_LIST=["Westminster","Kensington","Chelsea"]
AZURE_SPEECH_PHRASE_LIST_BY_DOMAIN={}
AZURE_SPEECH_PHRASE_LIST_BIAS=1.2
AZURE_SPEECH_DUAL_CHANNEL_ENABLED=true
AZURE_SPEECH_MAX_SPEAKERS=6
AZURE_SPEECH_BATCH_CUSTOM_MODEL_ID=
AZURE_SPEECH_ADDITIONAL_LOCALES=["en-GB","en-US"]
AZURE_BLOB_CONNECTION_STRING=<used by azure batch transcription to store results>
AZURE_CONTAINER_NAME=<name of container to store azure transcription results>

# === Google cloud ===
GOOGLE_CLOUD_PROJECT=<>
GOOGLE_CLOUD_LOCATION=<>
GOOGLE_APPLICATION_CREDENTIALS=/app/config/google-credentials.json
GOOGLE_APPLICATION_CREDENTIALS_BASE64=<base64 encoded json of the above. only used in docker container>


# === postgres ===
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=minute_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=insecure
POSTGRES_AUTH_MODE=password # or managed_identity
AZURE_MANAGED_IDENTITY_CLIENT_ID=
AZURE_KEY_VAULT_URI=

# === queue service ===
TRANSCRIPTION_QUEUE_NAME=minute-transcription-queue
TRANSCRIPTION_DEADLETTER_QUEUE_NAME=minute-transcription-queue-deadletter
LLM_QUEUE_NAME=minute-llm-queue
LLM_DEADLETTER_QUEUE_NAME=minute-llm-queue-deadletter
AZURE_SB_CONNECTION_STRING=

# === ray ===
RAY_DASHBOARD_HOST=127.0.0.1
RAY_NAMESPACE=minute
RAY_WORKER_REGISTER_TIMEOUT_MS=20000

# === exports & microsoft graph ===
MS_GRAPH_ENABLED=false
MS_GRAPH_SITE_ID=
MS_GRAPH_DRIVE_ID=
MS_GRAPH_LIBRARY_PATH=Shared Documents/Minutes
MS_GRAPH_DOMAIN_LIBRARY_PATHS={}
MS_GRAPH_PLAN_ID=
MS_GRAPH_BUCKET_ID=
MS_GRAPH_DOMAIN_PLAN_IDS={}
MS_GRAPH_ASSIGN_USER_ID=
EXPORT_URL_EXPIRY_SECONDS=3600
EXPORT_STORAGE_PREFIX=exports
METRICS_ENABLED=true
METRICS_PORT=9000
LONG_AUDIO_BATCH_THRESHOLD_SECONDS=3600
LLM_TOKEN_BUDGETS_PER_DOMAIN={}
LLM_MODEL_COST_WEIGHTS={}

# === required to authorise user in local development ===
REPO=minute

# === other ===
SENTRY_DSN=placeholder
POSTHOG_API_KEY=<>


DISABLE_AUTH_SIGNATURE_VERIFICATION=true # Only ever set to true in local environments
PII_ENCRYPTION_KEY=
