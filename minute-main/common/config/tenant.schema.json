{
  "$defs": {
    "LanguageConfig": {
      "properties": {
        "default": {
          "type": "string",
          "description": "Default language code (e.g. en)",
          "title": "Default"
        },
        "available": {
          "description": "List of languages that can be requested",
          "items": {
            "type": "string"
          },
          "title": "Available",
          "type": "array"
        },
        "autoTranslate": {
          "default": false,
          "description": "When true, automatically request translations after transcription completes",
          "title": "Autotranslate",
          "type": "boolean"
        }
      },
      "required": [
        "default"
      ],
      "title": "LanguageConfig",
      "type": "object"
    },
    "ModuleConfig": {
      "properties": {
        "id": {
          "description": "Module identifier, e.g. transcription, minutes",
          "title": "Id",
          "type": "string"
        },
        "enabled": {
          "default": true,
          "title": "Enabled",
          "type": "boolean"
        },
        "label": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Display label for navigation",
          "title": "Label"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional icon name for navigation",
          "title": "Icon"
        },
        "feature_flags": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional feature flag identifiers required for this module",
          "title": "Feature Flags"
        },
        "departments": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional list of service_domain ids this module applies to",
          "title": "Departments"
        }
      },
      "required": [
        "id"
      ],
      "title": "ModuleConfig",
      "type": "object"
    },
    "NavigationItem": {
      "properties": {
        "label": {
          "description": "Navigation label",
          "title": "Label",
          "type": "string"
        },
        "href": {
          "description": "Target href for the navigation item",
          "title": "Href",
          "type": "string"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional icon name for navigation",
          "title": "Icon"
        },
        "fab": {
          "default": false,
          "description": "Whether to render as a floating action button on mobile",
          "title": "Fab",
          "type": "boolean"
        },
        "roles": {
          "anyOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional list of roles allowed to see this navigation item",
          "title": "Roles"
        }
      },
      "required": [
        "label",
        "href"
      ],
      "title": "NavigationItem",
      "type": "object"
    }
  },
  "properties": {
    "id": {
      "description": "Stable tenant/council identifier",
      "title": "Id",
      "type": "string"
    },
    "name": {
      "title": "Name",
      "type": "string"
    },
    "version": {
      "description": "Config version tag, e.g. 1.0.0",
      "title": "Version",
      "type": "string"
    },
    "defaultLocale": {
      "pattern": "^[a-z]{2}-[A-Z]{2}$",
      "title": "Defaultlocale",
      "type": "string"
    },
    "designTokens": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Designtokens"
    },
    "retentionDaysDefault": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Default retention in days for recordings/transcriptions/minutes",
      "title": "Retentiondaysdefault"
    },
    "sharepoint_library_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Default SharePoint library path",
      "title": "Sharepoint Library Path"
    },
    "planner": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional Planner plan/bucket ids",
      "title": "Planner"
    },
    "languages": {
      "anyOf": [
        {
          "$ref": "#/$defs/LanguageConfig"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Language/translation configuration for the tenant"
    },
    "navigation": {
      "anyOf": [
        {
          "items": {
            "$ref": "#/$defs/NavigationItem"
          },
          "type": "array"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional navigation overrides",
      "title": "Navigation"
    },
    "modules": {
      "items": {
        "$ref": "#/$defs/ModuleConfig"
      },
      "title": "Modules",
      "type": "array"
    }
  },
  "required": [
    "id",
    "name",
    "version",
    "defaultLocale",
    "modules"
  ],
  "title": "TenantConfig",
  "type": "object"
}